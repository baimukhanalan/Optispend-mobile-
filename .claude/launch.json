{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web", "--port", "8081", "--clear"],
      "port": 8081,
      "env": {
        "CI": "1"
      }
    },
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--port", "8081"],
      "port": 8081,
      "env": {
        "CI": "1"
      }
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--android", "--port", "8081"],
      "port": 8081,
      "env": {
        "CI": "1"
      }
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios", "--port", "8081"],
      "port": 8081,
      "env": {
        "CI": "1"
      }
    },
    {
      "name": "Supabase Local",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["supabase", "start"],
      "port": 54321
    }
  ]
}
