# ─── Frontend (safe to expose) ───────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Backend secrets (Supabase Edge Functions only — NEVER in frontend) ──────
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI / OCR
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=                          # альтернатива OpenAI
GOOGLE_CLOUD_VISION_KEY=                 # для OCR чеков
MINDEE_API_KEY=                          # альтернатива GCV

# Notifications / Messaging
RESEND_API_KEY=re_...
TELEGRAM_BOT_TOKEN=bot...
EXPO_PUSH_ACCESS_TOKEN=

# Monitoring / Analytics
SENTRY_DSN=https://...@sentry.io/...
POSTHOG_API_KEY=phc_...

# Subscriptions
REVENUECAT_API_KEY=

# ─── Bank integrations (подключить позже) ─────────────────────────────────────
# KASPI_API_KEY=
# HALYK_API_KEY=
# FORTE_API_KEY=
